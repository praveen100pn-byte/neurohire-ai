{
  "name": "NeuroHire AI Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.10-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "app.py"
      ]
    },
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  
  // Install Linux dependencies for OCR and PDF processing
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y tesseract-ocr poppler-utils",

  "updateContentCommand": "python -m pip install --upgrade pip && pip install -r requirements.txt",

  "postCreateCommand": "pip install -r requirements.txt",

  "postAttachCommand": "streamlit run app.py --server.port 8501 --server.address 0.0.0.0 --server.enableCORS false --server.enableXsrfProtection false",

  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [8501]
}
